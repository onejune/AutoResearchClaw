#!/bin/bash
# 实验队列管理脚本 - 统一入口
# 路径自动推断，无硬编码，多项目并行安全

# 自动推断项目根目录（本脚本在 scripts/ 下，上一级即项目根）
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

QUEUE_MANAGER="$SCRIPT_DIR/experiment_queue_manager.py"
EXP_MANAGER="$PROJECT_DIR/experiment_manager.py"
MANAGE_SH="$SCRIPT_DIR/manage_experiments.sh"

cd "$PROJECT_DIR"

case "$1" in
    # ========== 队列管理 ==========
    list)
        python "$QUEUE_MANAGER" list $2
        ;;

    add)
        shift
        python "$QUEUE_MANAGER" add $@
        ;;

    update)
        shift
        python "$QUEUE_MANAGER" update $@
        ;;

    remove)
        shift
        python "$QUEUE_MANAGER" remove $@
        ;;

    export)
        python "$QUEUE_MANAGER" export
        echo "✅ 配置已导出，重启守护进程以生效"
        ;;

    # ========== 状态监控 ==========
    status)
        python "$EXP_MANAGER" --status
        ;;

    # ========== 守护进程控制 ==========
    start)
        "$MANAGE_SH" start
        ;;

    stop)
        "$MANAGE_SH" stop
        ;;

    restart)
        "$MANAGE_SH" restart
        ;;

    log)
        "$MANAGE_SH" log
        ;;

    # ========== 单个实验控制 ==========
    run)
        shift
        python "$EXP_MANAGER" --start $@
        ;;

    kill)
        shift
        python "$EXP_MANAGER" --stop $@
        ;;

    rerun)
        shift
        python "$EXP_MANAGER" --restart $@
        ;;

    # ========== 快捷命令 ==========
    dashboard)
        while true; do
            clear
            python "$EXP_MANAGER" --status
            echo ""
            echo "按 Ctrl+C 退出"
            sleep 5
        done
        ;;

    complete)
        shift
        python "$QUEUE_MANAGER" update --id $@ --completed
        echo "✅ 已标记完成，更新配置..."
        python "$QUEUE_MANAGER" export
        ;;

    help|--help|-h)
        echo "实验管理系统 - 统一入口"
        echo "项目目录：$PROJECT_DIR"
        echo ""
        echo "用法：$0 <命令> [参数]"
        echo ""
        echo "队列管理:"
        echo "  list [--status pending|completed]    列出实验"
        echo "  add --id XXX --name XXX ...          添加实验"
        echo "  update --id XXX --priority N         更新实验"
        echo "  remove --id XXX                      移除实验"
        echo "  export                               导出配置"
        echo ""
        echo "状态监控:"
        echo "  status                               查看当前状态"
        echo "  dashboard                            实时仪表盘"
        echo ""
        echo "守护进程:"
        echo "  start                                启动守护进程"
        echo "  stop                                 停止守护进程"
        echo "  restart                              重启守护进程"
        echo "  log                                  查看日志"
        echo ""
        echo "实验控制:"
        echo "  run expXXX                           启动实验"
        echo "  kill expXXX                          停止实验"
        echo "  rerun expXXX                         重启实验"
        echo "  complete expXXX                      标记完成"
        ;;

    *)
        echo "未知命令：$1"
        echo ""
        $0 help
        exit 1
        ;;
esac
